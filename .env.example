TWITTER_BEARER_TOKEN=
OPENROUTER_API_KEY=your_openrouter_api_key

# Required when DRY_RUN=false — OAuth 2.0 user context (posting account)
TWITTER_OAUTH2_ACCESS_TOKEN=

# Optional config
CONFIG_ACCOUNTS=user1,user2
CONFIG_MIN_ENGAGEMENT=0
CONFIG_MAX_REPLIES_PER_DAY=5
CONFIG_COOLDOWN_HOURS=24
CONFIG_REPLY_TONE=engaging
CONFIG_MAX_REPLY_LENGTH=260
CONFIG_INCLUDE_EMOJI=true
CONFIG_ASK_QUESTIONS=true
CONFIG_EXCLUDE_REPLIES=true
CONFIG_EXCLUDE_RETWEETS=true
OPENROUTER_MODEL=auto
OPENROUTER_MAX_TOKENS=100
OPENROUTER_TEMPERATURE=0.7
COST_LIMIT_USD=10
DRY_RUN=true
LOG_LEVEL=INFO
